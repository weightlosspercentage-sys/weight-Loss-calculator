---
import { getLocalizedHref } from '../utils/navigation';
import { regions } from '../data/localization.json';
---

<header class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container flex h-14 max-w-screen-2xl items-center">
    <a href="/" class="mr-6 flex items-center space-x-2">
      <span class="font-bold sm:inline-block">WeightLossPercentage</span>
    </a>
    <nav class="flex items-center gap-6 text-sm">
      <a href="/calculators" class="transition-colors hover:text-foreground/80 text-foreground/60">Calculators</a>
      <a href="/blog" class="transition-colors hover:text-foreground/80 text-foreground/60">Blog</a>
      <a href="/nutrition" class="transition-colors hover:text-foreground/80 text-foreground/60">Nutrition</a>
    </nav>
  </div>
</header>
