---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculators } from '../../data/calculators.json';
import { blogs } from '../../data/blogs.json';
import { regions } from '../../data/localization.json';
import { WeightLossCalculator } from '../../components/Calculators/WeightLossCalculator';

export async function getStaticPaths() {
  const paths = [];

  // Generate calculator pages for all regions
  for (const region of Object.keys(regions)) {
    for (const calc of calculators) {
      paths.push({
        params: {
          path: `${region}/calculators/${calc.id}`
        },
        props: {
          pageType: 'calculator',
          data: calc
        }
      });
    }
  }

  // Generate blog pages for all regions
  for (const region of Object.keys(regions)) {
    for (const blog of blogs) {
      paths.push({
        params: {
          path: `${region}/blog/${blog.slug}`
        },
        props: {
          pageType: 'blog',
          data: blog
        }
      });
    }
  }

  // Generate homepages for all regions
  for (const region of Object.keys(regions)) {
    paths.push({
      params: {
        path: region
      },
      props: {
        pageType: 'home',
        data: {}
      }
    });
  }

  return paths;
}

const { pageType, data } = Astro.props;
---

<BaseLayout title={data.title || 'Weight Loss Percentage Calculator'} description={data.meta_desc || ''}>
  {pageType === 'calculator' && (
    <div class="container mx-auto py-8">
      <WeightLossCalculator client:load />
    </div>
  )}

  {pageType === 'blog' && (
    <article class="container mx-auto py-8 prose">
      <h1>{data.h1}</h1>
      <p>By {data.author_name}</p>
      <div set:html={data.content_md.replace(/\\n/g, '<br/>')} />
    </article>
  )}

  {pageType === 'home' && (
    <div class="container mx-auto py-8">
      <h1>Welcome to the homepage!</h1>
    </div>
  )}
</BaseLayout>
