---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseHtmlPageV2 as parseHtmlPage } from '../utils/parser_v2';
import { getRegionFromPath } from '../utils/navigation';

const filePath = 'index.html';
const parsed = parseHtmlPage(filePath, true);
const region = getRegionFromPath(filePath);
---
<BaseLayout lang={parsed.lang} {...parsed.seoProps} activePath="" region={region} loadReact={true}>
  <Fragment set:html={parsed.headContent} slot="head" />
  <Fragment set:html={parsed.bodyContent} />
</BaseLayout>
