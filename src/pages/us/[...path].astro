---
import fs from 'fs';
import path from 'path';

export function getStaticPaths() {
  const rootDir = process.cwd();
  const subdirs = [
    'about',
    'blog',
    'calculators',
    'category',
    'compare',
    'contact',
    'disclaimer',
    'glossary',
    'nutrition',
    'privacy',
    'restaurants',
    'terms'
  ];
  
  const paths = [
    { params: { path: undefined } } // Matches /us and /us/
  ];
  
  // Recursively find index.html files to get all possible routes
  function scanDir(dir) {
    if (!fs.existsSync(dir)) return;
    // Exclude programmatic height-weight pages to prevent bloated builds
    if (dir.includes('height-weight')) return;
    
    // Dev performance optimization: Skip scanning massive weight progression folders
    if (import.meta.env.DEV) {
      const baseName = path.basename(dir);
      if (baseName.startsWith('from-') || baseName.includes('-to-')) {
        return;
      }
    }
    
    const entries = fs.readdirSync(dir, { withFileTypes: true });
    for (const entry of entries) {
      const fullPath = path.join(dir, entry.name);
      if (entry.isDirectory()) {
        scanDir(fullPath);
      } else if (entry.name === 'index.html') {
        // Calculate clean path relative to rootDir
        let rel = path.relative(rootDir, dir).replace(/\\/g, '/');
        paths.push({ params: { path: rel } });
      }
    }
  }
  
  for (const subdir of subdirs) {
    scanDir(path.join(rootDir, subdir));
  }
  
  return paths;
}

const { path: paramPath } = Astro.params;
const cleanPath = paramPath ? paramPath.replace(/^\/+|\/+$/g, '') : '';
const targetPath = cleanPath ? `/${cleanPath}/` : '/';
const absoluteTarget = `https://www.weightlosspercentage.com${targetPath}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting | Weight Loss Percentage</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={absoluteTarget} />
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
  </head>
  <body>
    <p>Redirecting to <a href={targetPath}>{targetPath}</a>...</p>
    <nav aria-label="Site navigation">
      <ul>
        <li><a href="/">Weight Loss Percentage Calculator</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </nav>
    <script is:inline define:vars={{ targetPath }}>
      window.location.replace(targetPath);
    </script>
  </body>
</html>
