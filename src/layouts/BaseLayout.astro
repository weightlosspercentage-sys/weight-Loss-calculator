---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

export interface Props {
  lang?: string;
  title?: string;
  description?: string;
  canonical?: string;
  alternates?: Array<{ hreflang: string; href: string }>;
  metaTags?: Array<{ name?: string; property?: string; content: string }>;
  schemas?: string[];
  activePath?: string;
  region: string;
  loadReact?: boolean;
}

const { 
  lang = 'en', 
  title,
  description,
  canonical,
  alternates,
  metaTags,
  schemas,
  activePath = '', 
  region,
  loadReact = false
} = Astro.props;
---

<!doctype html>
<html lang={lang} class={loadReact ? "has-react" : ""}>
  <head>
    <link rel="stylesheet" href="/assets/index-43gqMy96.css" />
    <link rel="stylesheet" href="/assets/vercel-overrides.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <SEO 
      title={title}
      description={description}
      canonical={canonical || Astro.url.href}
      alternates={alternates}
      metaTags={metaTags}
      schemas={schemas}
    />
    <!-- Security Headers (client-side equivalents) -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()" />
    <script define:vars={{ region }} is:inline>
      window.__ROUTE_BASEPATH__ = region ? `/${region}` : "/";
    </script>
    <slot name="head" />
    <style is:global>
      :root {
        --vercel-primary: #171717;
        --vercel-on-primary: #ffffff;
        --vercel-ink: #171717;
        --vercel-body: #4d4d4d;
        --vercel-mute: #888888;
        --vercel-hairline: #ebebeb;
        --vercel-canvas: #ffffff;
        --vercel-canvas-soft: #fafafa;
        --vercel-link: #0070f3;
        --vercel-success: #0070f3;
        --vercel-error: #ee0000;
        --vercel-radius: 6px;
        --vercel-radius-md: 8px;
        --vercel-radius-pill: 100px;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
      }
      body {
        font-family: var(--font-sans);
        background-color: var(--vercel-canvas-soft);
        color: var(--vercel-ink);
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3, h4, h5, h6 {
        letter-spacing: -0.03em;
        font-weight: 600;
      }
      
      /* Critical styles to prevent Flash of Unstyled Content (FOUC) */
      .hidden { display: none !important; }
      /* Responsive overrides — must be !important to beat the .hidden rule above */
      @media (min-width: 640px) {
        .sm\:block  { display: block  !important; }
        .sm\:flex   { display: flex   !important; }
        .sm\:inline { display: inline !important; }
      }
      @media (min-width: 768px) {
        .md\:flex   { display: flex   !important; }
        .md\:block  { display: block  !important; }
        .md\:hidden { display: none   !important; }
      }
      /* Interaction-state overrides — dropdowns use hidden + group-hover:block */
      .group:hover .group-hover\:block,
      .group:focus-within .group-focus-within\:block { display: block !important; }
      .group:hover .group-hover\:flex,
      .group:focus-within .group-focus-within\:flex  { display: flex  !important; }

      /* Hide outer static layout elements when React is loaded */
      html.has-react .static-header,
      html.has-react .static-footer,
      /* Hide all static fallback content inside #root - use direct child selectors (>)
         so we don't accidentally match React's nested components inside the #root wrapper div */
      html.has-react #root > header,
      html.has-react #root > footer,
      html.has-react #root > nav,
      html.has-react #root > #mobileMenuScript,
      html.has-react #root > #main-content {
        display: none !important;
      }

      /* Spinner animation for the layout-level loader */
      @keyframes layout-spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
            
      /* Standard layout styles matching index.html */
      .focus-visible-outline { outline: none; }
      .focus-visible-ring:focus-visible { box-shadow: 0 0 0 2px #6366f1; border-radius: 6px; }
      
      /* Dropdown transitions with slide and fade */
      .dropdown-menu {
        opacity: 0;
        transform: translateY(8px);
        pointer-events: none;
        position: absolute;
        z-index: 100;
        transition: opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1), transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .group:hover .dropdown-menu,
      .group:focus-within .dropdown-menu {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      
      /* Chevron rotation */
      .dropdown-chevron {
        transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .group:hover .dropdown-chevron,
      .group:focus-within .dropdown-chevron {
        transform: rotate(180deg);
      }

      /* Navigation active and hover link indicator */
      .nav-link {
        position: relative;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 12px;
        right: 12px;
        height: 2px;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6, #f97316);
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .nav-link:hover::after,
      .nav-link.active::after {
        transform: scaleX(1);
        transform-origin: left;
      }

      .mobile-details summary::-webkit-details-marker { display: none; }
      .mobile-details[open] .mobile-chevron { transform: rotate(180deg); }
    </style>
  </head>
  <body>
    <!-- Page loader: covers content while React bundle loads/mounts -->
    <div id="layout-loader" style="position: fixed; inset: 0; background: #ffffff; display: flex; align-items: center; justify-content: center; z-index: 9999; pointer-events: none; transition: opacity 0.25s ease;">
      <div style="width: 44px; height: 44px; border: 3px solid #e2e8f0; border-top: 3px solid #4f46e5; border-radius: 50%; animation: layout-spin 0.75s linear infinite;"></div>
    </div>
    {!loadReact && <Header activePath={activePath} region={region} />}
    <div id="root">
      <slot />
      
      <!-- Global Medical Disclaimer & Educational Guidance (EEAT / YMYL) -->
      <div style="max-width: 800px; margin: 3rem auto 1rem; padding: 1.5rem; background: #fcfcfc; border: 1px solid #e2e8f0; border-radius: 12px; font-family: sans-serif; text-align: left; color: #475569; font-size: 0.85rem; line-height: 1.5;">
        <div style="margin: 0 0 0.5rem; font-size: 0.95rem; font-weight: 700; color: #1e293b;">Medical Disclaimer & Evidence-Based Guidelines</div>
        <p style="margin: 0 0 0.75rem;">
          <strong>Educational Resource Only:</strong> The metrics, tools, and deficit projections displayed on Weight Loss Percentage are designed to support personal goal tracking and promote healthy weight management. They do not constitute formal medical diagnoses or clinical treatment plans. Please consult a registered dietitian or healthcare professional before embarking on restrictive dieting or intensive physical training.
        </p>
        <p style="margin: 0 0 0.75rem;">
          <strong>Healthy Weight Loss Standards:</strong> Clinical evidence suggests that a safe and sustainable rate of fat loss is approximately 1 to 2 pounds per week (or 0.5% to 1.0% of your total body weight). Rapid weight reduction can lead to metabolic adaptation, lean muscle loss, and nutritional deficiencies. Tracking your weight loss percentage rather than raw pounds provides a more accurate metric of progress relative to your unique frame and initial body mass index.
        </p>
        <p style="margin: 0;">
          <strong>Deficit Projections:</strong> Calculators like BMR, TDEE, and calorie deficit models estimate energy expenditure based on baseline physiological variables. Actual metabolic rates vary due to lean body mass distribution, hormonal health, activity levels, and individual adaptation. Adjust caloric targets gradually while prioritizing nutrient-dense whole foods to optimize energy levels and sustain your metabolic health.
        </p>
      </div>
      
    </div>
    {!loadReact && <Footer relativePath={activePath} region={region} />}
    <!-- Dismiss loader once React has fully rendered -->
    <script is:inline>
      (function() {
        function dismissLoader() {
          var loader = document.getElementById('layout-loader');
          if (!loader) return;
          loader.style.opacity = '0';
          setTimeout(function() {
            if (loader && loader.parentNode) loader.parentNode.removeChild(loader);
          }, 250);
        }
        // Dismiss when window fully loads (scripts executed, React mounted)
        window.addEventListener('load', dismissLoader);
        // Safety fallback: dismiss after 4 seconds no matter what
        setTimeout(dismissLoader, 4000);
      })();
    </script>
  </body>
</html>
