            <li><a href={getLocalizedHref('/calculators/calorie/', region)} style="color: #94a3b8; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#94a3b8'">Calorie Calculator</a></li>
