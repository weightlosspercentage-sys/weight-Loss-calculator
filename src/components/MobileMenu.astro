---
import { navLinks, getLocalizedHref } from '../utils/navigation';

export interface Props {
  region: string;
  activePath?: string;
}

const { region, activePath } = Astro.props;

const isLinkActive = (href: string) => {
  if (!activePath) return false;
  const normHref = href.endsWith('/') ? href : href + '/';
  const normActive = activePath.endsWith('/') ? activePath : activePath + '/';
  if (normHref === '/' || normHref === '/uk/' || normHref === '/ca/' || normHref === '/au/' || normHref === '/nz/' || normHref === '/zh/' || normHref === '/ru/') {
    return normActive === normHref;
  }
  return normActive.startsWith(normHref);
};
---

<div id="mobile-menu" class="md:hidden hidden pb-4 px-4 space-y-1 transition-all duration-300 ease-in-out overflow-hidden" style="max-height: 0px; opacity: 0;">
  {navLinks.map((link) => {
    if ('dropdown' in link) {
      const parentHref = getLocalizedHref(link.label === 'Calculators' ? '/calculators/' : '/nutrition/', region);
      const isParentActive = isLinkActive(parentHref);
      return (
        <details class="mobile-details" open={isParentActive}>
          <summary class={`px-4 py-3 min-h-11 text-sm font-medium rounded-md cursor-pointer list-none flex justify-between items-center ${isParentActive ? 'text-indigo-700 bg-indigo-50/50' : 'text-gray-700 hover:bg-gray-50'}`}>
            {link.label}
            <svg class="w-4 h-4 mobile-chevron transition-transform duration-200" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="pl-4 space-y-1 mt-1 border-l-2 border-indigo-100 ml-4">
            {link.dropdown?.map((subItem) => {
              const subHref = getLocalizedHref(subItem.href, region);
              const isSubActive = isLinkActive(subHref);
              return (
                <a 
                  href={subHref} 
                  class={subItem.isSpecial 
                    ? `block px-4 py-3 min-h-11 text-sm font-semibold rounded-md ${isSubActive ? 'text-orange-800 bg-orange-50' : 'text-orange-700 hover:bg-orange-50/50'}`
                    : `block px-4 py-3 min-h-11 text-sm rounded-md ${isSubActive ? 'text-indigo-700 bg-indigo-50 font-semibold' : 'text-gray-600 hover:bg-gray-50'}`
                  }
                >
                  {subItem.label}
                </a>
              );
            })}
          </div>
        </details>
      );
    } else {
      const linkHref = getLocalizedHref(link.href, region);
      const isAct = isLinkActive(linkHref);
      return (
        <a 
          href={linkHref} 
          class={`block px-4 py-3 min-h-11 text-sm font-medium rounded-md ${isAct ? 'text-indigo-700 bg-indigo-50' : 'text-gray-700 hover:bg-gray-50'}`}
        >
          {link.label}
        </a>
      );
    }
  })}
</div>
