---
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
import { getLocalizedHref } from '../utils/navigation';

export interface Props {
  activePath?: string;
  region: string;
}

const { region, activePath } = Astro.props;
---

<header class="static-header" style="position: sticky; top: 0; z-index: 50; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--vercel-hairline); height: 64px; display: flex; align-items: center; justify-content: center; padding: 0 16px;">
  <div style="max-width: 1400px; width: 100%; display: flex; justify-content: space-between; align-items: center; height: 100%;">
    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
      <!-- Logo -->
      <a href={getLocalizedHref('/', region)} style="display: flex; align-items: center; gap: 8px; text-decoration: none;" aria-label="Weight Loss Percentage — Home">
        <div style="height: 28px; width: 28px; background-color: var(--vercel-primary); border-radius: var(--vercel-radius); display: flex; align-items: center; justify-content: center; color: var(--vercel-on-primary); font-weight: 600; font-family: var(--font-mono); font-size: 14px; letter-spacing: 0;" aria-hidden="true">%</div>
        <span style="font-weight: 600; color: var(--vercel-ink); font-size: 16px; letter-spacing: -0.03em;">Weight Loss Percentage</span>
      </a>

      <!-- Desktop Navigation -->
      <Navigation region={region} activePath={activePath} />

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" aria-label="Open menu" class="md:hidden" style="display: flex; align-items: center; justify-center; height: 44px; width: 44px; border: none; background: transparent; cursor: pointer; color: var(--vercel-ink);">
        <svg style="height: 24px; width: 24px;" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <MobileMenu region={region} />
</header>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
    var m = document.getElementById('mobile-menu');
    if (m) {
      if (m.classList.contains('hidden')) {
        m.classList.remove('hidden');
        // Allow a frame for browser layout and then transition properties
        requestAnimationFrame(function() {
          m.style.maxHeight = m.scrollHeight + 'px';
          m.style.opacity = '1';
        });
      } else {
        m.style.maxHeight = '0px';
        m.style.opacity = '0';
        m.addEventListener('transitionend', function handler(e) {
          if (e.propertyName === 'max-height') {
            m.classList.add('hidden');
            m.removeEventListener('transitionend', handler);
          }
        });
      }
      var isHidden = m.classList.contains('hidden');
      this.setAttribute('aria-label', isHidden ? 'Open menu' : 'Close menu');
    }
  });
</script>
