# ─── HTTPS Redirect ───
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── www redirect (non-www → www) ───
RewriteCond %{HTTP_HOST} ^weightlosspercentage\.com$ [NC]
RewriteRule ^ https://www.weightlosspercentage.com%{REQUEST_URI} [L,R=301]

# ─── 301 Redirect index.html to Trailing Slash URLs ───
# Direct requests for index.html at root
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/ [NC]
RewriteRule ^index\.html$ https://www.weightlosspercentage.com/ [R=301,L]

# Direct requests for index.html in subdirectories
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^/]+/)*index\.html\ HTTP/ [NC]
RewriteRule ^(([^/]+/)*)index\.html$ https://www.weightlosspercentage.com/$1 [R=301,L]

# ─── 301 Redirects from Old/Legacy Paths to New Active Paths ───
# Legacy HTML pages
Redirect 301 /weight-loss-percentage-calculator-newborn.html https://www.weightlosspercentage.com/calculators/newborn-weight-loss
